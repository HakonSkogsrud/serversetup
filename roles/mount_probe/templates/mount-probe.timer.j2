[Unit]
Description=Run mount responsiveness probe on a fixed interval
Documentation=man:systemd.timer(5)

[Timer]
OnBootSec={{ mount_probe_timer_on_boot_sec }}
OnUnitActiveSec={{ mount_probe_timer_on_unit_active_sec }}
AccuracySec={{ mount_probe_timer_accuracy_sec }}

[Install]
WantedBy=timers.target
