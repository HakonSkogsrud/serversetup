#!/bin/bash
set -e

# Configuration
SCRIPT_NAME="{{ uptimekuma_script_name }}"
DATA_DIR="{{ uptimekuma_data_dir }}"
BACKUP_ROOT="{{ uptimekuma_backup_dir }}"
BACKUP_PATH="$BACKUP_ROOT/uk_$(date +%Y%m%d_%H%M%S).tar.gz"
KEEP_COUNT=7

# Notify
logger -t "$SCRIPT_NAME" "Starting uptimekuma backup"

# Stop container to ensure data integrity
cd "{{ uptimekuma_data_dir | dirname }}"
docker compose -f "{{ uptimekuma_data_dir }}/../docker-compose.yml" stop uptime-kuma || true

# Create backup
tar -czf "$BACKUP_PATH" -C "$DATA_DIR" .

# Restart container
docker compose -f "{{ uptimekuma_data_dir }}/../docker-compose.yml" start uptime-kuma || true

# Cleanup: Sort by date and keep only the most recent backups
cd "$BACKUP_ROOT"
ls -1dt uk_*.tar.gz | tail -n +$((KEEP_COUNT + 1)) | xargs rm -f 2>/dev/null || true

logger -t "$SCRIPT_NAME" "Backup completed: $BACKUP_PATH"
